# Copie este arquivo para .env.local (já ignorado pelo git via *.local) e preencha
# com os dados do SEU projeto Supabase (Project Settings → API).

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# NUNCA coloque a service_role key aqui — ela nunca deve ir para o frontend/git.
# Se precisar dela (ex: em uma Edge Function), configure como secret no dashboard do Supabase.
